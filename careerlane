<div class="modal-overlay" id="modalOverlay">
  <div class="modal-box">
    <button class="back-btn" id="backBtn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
      Back to Portfolio
    </button>
    <div class="modal-frame">
      <img id="modalImg" src="" alt="">
    </div>
    <div class="modal-caption">
      <span class="cert-exhibit" id="modalExhibit"></span>
      <h3 id="modalName"></h3>
      <p id="modalIssuer"></p>
    </div>
  </div>
</div>

<script>
  const overlay = document.getElementById('modalOverlay');
  const modalImg = document.getElementById('modalImg');
  const modalName = document.getElementById('modalName');
  const modalIssuer = document.getElementById('modalIssuer');
  const modalExhibit = document.getElementById('modalExhibit');
  const backBtn = document.getElementById('backBtn');

  document.querySelectorAll('.cert-card').forEach(card => {
    card.addEventListener('click', () => {
      const thumbImg = card.querySelector('.cert-thumb img');
      // Reuse the already-resolved image source (currentSrc) rather than
      // re-requesting the raw path, so it loads reliably in every environment.
      modalImg.src = (thumbImg && (thumbImg.currentSrc || thumbImg.src)) || card.dataset.img;
      modalImg.alt = card.dataset.name;
      modalName.textContent = card.dataset.name;
      modalIssuer.textContent = card.dataset.issuer;
      modalExhibit.textContent = card.querySelector('.cert-exhibit').textContent;
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeModal(){
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }
  backBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => { if(e.target === overlay) closeModal(); });
  document.addEventListener('keydown', (e) => { if(e.key === 'Escape') closeModal(); });
</script>

