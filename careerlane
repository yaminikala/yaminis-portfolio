<style>
  :root{
    --paper:#F7F3E9;
    --paper-deep:#EFE9D8;
    --ink:#1C2420;
    --ink-soft:#4A544C;
    --navy:#0E2038;
    --navy-deep:#081527;
    --teal:#1B4B45;
    --stamp:#AE3A2C;
    --stamp-dark:#8C2E22;
    --gold:#B4922E;
    --line:#D8D0B8;
    --line-dark:#2A3A4E;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--paper);
    color:var(--ink);
    font-family:'IBM Plex Sans', sans-serif;
    line-height:1.6;
  }
  ::selection{background:var(--stamp);color:var(--paper);}
  a{color:inherit;}

  .label{
    font-family:'IBM Plex Mono', monospace;
    font-size:11px;
    letter-spacing:.14em;
    text-transform:uppercase;
  }

  /* ===== NAV ===== */
  header.topnav{
    position:sticky; top:0; z-index:50;
    background:rgba(247,243,233,.92);
    backdrop-filter:blur(6px);
    border-bottom:1px solid var(--line);
  }
  .nav-inner{
    max-width:1120px; margin:0 auto;
    display:flex; align-items:center; justify-content:space-between;
    padding:16px 28px;
  }
  .nav-mark{
    font-family:'Fraunces', serif; font-weight:600; font-size:19px;
    display:flex; align-items:center; gap:10px;
  }
  .nav-mark .dot{
    width:9px;height:9px;border-radius:50%;background:var(--stamp);
    box-shadow:0 0 0 3px rgba(174,58,44,.15);
  }
  nav.links{display:flex; gap:28px;}
  nav.links a{
    font-family:'IBM Plex Mono', monospace;
    font-size:11.5px; letter-spacing:.1em; text-transform:uppercase;
    text-decoration:none; color:var(--ink-soft);
    border-bottom:1px solid transparent;
    padding-bottom:3px;
    transition:color .2s, border-color .2s;
  }
  nav.links a:hover{color:var(--stamp); border-color:var(--stamp);}

  /* ===== HERO / REPORT HEADER ===== */
  .hero{
    background:
      radial-gradient(circle at 88% 12%, rgba(180,146,46,.14), transparent 45%),
      var(--navy);
    color:var(--paper);
    position:relative;
    overflow:hidden;
    border-bottom:6px solid var(--stamp);
  }
  .hero::before{
    content:"";
    position:absolute; inset:0;
    background-image:
      repeating-linear-gradient(0deg, rgba(255,255,255,.035) 0px, rgba(255,255,255,.035) 1px, transparent 1px, transparent 34px);
    pointer-events:none;
  }
  .hero-inner{
    max-width:1120px; margin:0 auto;
    padding:64px 28px 56px;
    position:relative;
  }
  .report-meta{
    display:flex; justify-content:space-between; align-items:flex-start;
    flex-wrap:wrap; gap:16px;
    font-family:'IBM Plex Mono', monospace;
    font-size:11px; letter-spacing:.12em; text-transform:uppercase;
    color:#9FB0C4;
    border-bottom:1px solid rgba(255,255,255,.15);
    padding-bottom:18px; margin-bottom:38px;
  }
  .report-meta span b{color:var(--paper); font-weight:600;}

  .hero-name{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:clamp(42px, 7vw, 74px);
    letter-spacing:-.01em;
    line-height:1.02;
  }
  .hero-role{
    margin-top:12px;
    font-size:18px;
    color:#C8D2DE;
    max-width:640px;
  }
  .hero-role strong{color:var(--paper); font-weight:600;}

  .status-row{
    margin-top:38px;
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
    gap:0;
    border-top:1px solid rgba(255,255,255,.15);
  }
  .status-cell{
    padding:18px 22px 18px 0;
    border-right:1px solid rgba(255,255,255,.15);
  }
  .status-cell:last-child{border-right:none;}
  .status-cell .label{color:#7E93AC; margin-bottom:6px; display:block;}
  .status-cell .value{
    font-family:'IBM Plex Mono', monospace;
    font-size:14.5px; color:var(--paper); font-weight:500;
  }
  .status-cell .value.verified{
    color:#7FD9A8;
    display:flex; align-items:center; gap:7px;
  }
  .verified-mark{
    display:inline-flex; align-items:center; justify-content:center;
    width:16px;height:16px; border-radius:50%;
    border:1.5px solid #7FD9A8; font-size:10px;
  }

  /* stamp element */
  .stamp{
    position:absolute; top:52px; right:28px;
    width:118px; height:118px;
    border:2px solid var(--stamp);
    border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    transform:rotate(-14deg);
    opacity:.9;
    mix-blend-mode:screen;
  }
  .stamp::before{
    content:"";
    position:absolute; inset:8px;
    border:1px solid var(--stamp);
    border-radius:50%;
  }
  .stamp svg{width:100%; height:100%;}
  .stamp text{
    font-family:'IBM Plex Mono', monospace;
    font-size:8.6px; letter-spacing:2px;
    fill:var(--stamp); text-transform:uppercase;
  }
  @media (max-width:640px){ .stamp{display:none;} }

  /* ===== SECTION SHELL ===== */
  section{max-width:1120px; margin:0 auto; padding:78px 28px;}
  .section-head{
    display:flex; align-items:baseline; gap:16px;
    margin-bottom:38px;
    border-bottom:1px solid var(--line);
    padding-bottom:16px;
  }
  .section-head .num{
    font-family:'IBM Plex Mono', monospace;
    color:var(--stamp); font-size:13px;
  }
  .section-head h2{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:30px;
  }
  .section-head .rule{flex:1; height:1px;}

  /* ===== SUMMARY ===== */
  .summary-text{
    font-size:17.5px; color:var(--ink-soft); max-width:760px;
  }
  .comp-grid{
    margin-top:40px;
    display:flex; flex-wrap:wrap; gap:10px;
  }
  .comp-tag{
    font-family:'IBM Plex Mono', monospace;
    font-size:12px; letter-spacing:.04em;
    padding:9px 14px;
    border:1px solid var(--line);
    background:var(--paper-deep);
    color:var(--teal);
  }

  /* ===== EXPERIENCE ===== */
  .job{
    display:grid;
    grid-template-columns:170px 1fr;
    gap:24px;
    padding:26px 0;
    border-bottom:1px solid var(--line);
  }
  .job:first-of-type{padding-top:0;}
  .job-dates{
    font-family:'IBM Plex Mono', monospace;
    font-size:12px; color:var(--ink-soft);
    padding-top:4px;
  }
  .job-title{
    font-family:'Fraunces', serif;
    font-weight:600; font-size:20px;
    margin-bottom:2px;
  }
  .job-company{
    font-family:'IBM Plex Mono', monospace;
    font-size:12px; color:var(--stamp);
    text-transform:uppercase; letter-spacing:.06em;
    margin-bottom:12px;
  }
  .job ul{list-style:none; display:flex; flex-direction:column; gap:8px;}
  .job li{
    position:relative; padding-left:18px;
    color:var(--ink-soft); font-size:15px;
  }
  .job li::before{
    content:"—";
    position:absolute; left:0; color:var(--line-dark);
    color:var(--gold);
  }
  @media (max-width:600px){
    .job{grid-template-columns:1fr;}
  }

  /* ===== CERTIFICATIONS GALLERY ===== */
  .cert-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(230px,1fr));
    gap:22px;
  }
  .cert-card{
    background:var(--navy);
    border:1px solid var(--line-dark);
    cursor:pointer;
    text-align:left;
    padding:0;
    display:flex; flex-direction:column;
    overflow:hidden;
    transition:transform .25s ease, box-shadow .25s ease;
    font-family:inherit;
  }
  .cert-card:hover{
    transform:translateY(-4px);
    box-shadow:0 14px 28px rgba(14,32,56,.22);
  }
  .cert-thumb{
    position:relative;
    height:230px;
    overflow:hidden;
    background:#fff;
    display:flex; align-items:center; justify-content:center;
    padding:10px;
  }
  .cert-thumb img{
    max-width:100%; max-height:100%;
    width:auto; height:auto;
    object-fit:contain;
    display:block;
    transition:transform .35s ease;
  }
  .cert-card:hover .cert-thumb img{transform:scale(1.04);}
  .cert-exhibit{
    position:absolute; top:10px; left:10px;
    background:var(--stamp); color:var(--paper);
    font-family:'IBM Plex Mono', monospace;
    font-size:10.5px; letter-spacing:.08em;
    padding:4px 8px;
  }
  .cert-info{
    padding:16px 16px 18px;
    color:var(--paper);
  }
  .cert-name{
    font-family:'Fraunces', serif;
    font-weight:600; font-size:15.5px;
    margin-bottom:6px; line-height:1.25;
  }
  .cert-issuer{
    font-family:'IBM Plex Mono', monospace;
    font-size:10.5px; letter-spacing:.08em; text-transform:uppercase;
    color:#8FA3BA;
  }

  /* ===== EDUCATION ===== */
  .edu-item{
    display:flex; justify-content:space-between; gap:20px;
    padding:16px 0; border-bottom:1px solid var(--line);
    flex-wrap:wrap;
  }
  .edu-item:last-child{border-bottom:none;}
  .edu-degree{font-weight:600; font-size:15.5px;}
  .edu-school{color:var(--ink-soft); font-size:14px; margin-top:2px;}
  .edu-year{
    font-family:'IBM Plex Mono', monospace; font-size:13px; color:var(--stamp);
  }

  /* ===== CONTACT / FOOTER ===== */
  footer{
    background:var(--navy-deep);
    color:var(--paper);
    padding:64px 28px 40px;
  }
  .footer-inner{max-width:1120px; margin:0 auto;}
  .footer-inner h2{
    font-family:'Fraunces', serif; font-size:32px; font-weight:600;
    max-width:600px; margin-bottom:28px;
  }
  .contact-grid{
    display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
    gap:20px; padding-top:28px; border-top:1px solid rgba(255,255,255,.15);
  }
  .contact-grid .label{color:#7E93AC; margin-bottom:6px; display:block;}
  .contact-grid .value{font-family:'IBM Plex Mono', monospace; font-size:14px;}
  .foot-note{
    margin-top:40px; font-family:'IBM Plex Mono', monospace;
    font-size:11px; color:#5E7089; letter-spacing:.06em;
  }

  /* ===== MODAL / EXHIBIT VIEW ===== */
  .modal-overlay{
    position:fixed; inset:0; z-index:200;
    background:rgba(8,15,25,.92);
    display:none;
    align-items:center; justify-content:center;
    padding:32px 20px;
  }
  .modal-overlay.open{display:flex;}
  .modal-box{
    max-width:920px; width:100%;
    max-height:92vh;
    display:flex; flex-direction:column;
    align-items:center;
  }
  .back-btn{
    align-self:flex-start;
    display:inline-flex; align-items:center; gap:9px;
    background:var(--stamp);
    color:var(--paper);
    border:none;
    font-family:'IBM Plex Mono', monospace;
    font-size:12.5px; letter-spacing:.08em; text-transform:uppercase;
    padding:11px 18px;
    cursor:pointer;
    margin-bottom:18px;
    transition:background .2s;
  }
  .back-btn:hover{background:var(--stamp-dark);}
  .back-btn svg{width:14px; height:14px;}
  .modal-frame{
    background:#fff;
    padding:10px;
    max-height:70vh;
    display:flex; align-items:center; justify-content:center;
    overflow:hidden;
    border:1px solid rgba(255,255,255,.15);
  }
  .modal-frame img{
    max-width:100%; max-height:68vh; object-fit:contain; display:block;
  }
  .modal-caption{
    margin-top:18px; text-align:center; color:var(--paper);
  }
  .modal-caption .cert-exhibit{position:static; display:inline-block; margin-bottom:8px;}
  .modal-caption h3{
    font-family:'Fraunces', serif; font-weight:600; font-size:20px;
  }
  .modal-caption p{
    margin-top:4px;
    font-family:'IBM Plex Mono', monospace;
    font-size:11.5px; letter-spacing:.06em; text-transform:uppercase;
    color:#8FA3BA;
  }

  @media (prefers-reduced-motion:reduce){
    *{animation:none !important; transition:none !important;}
  }
</style>
</head>
